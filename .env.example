# Supabase — frontend (público)
NEXT_PUBLIC_SUPABASE_URL=https://mfrawrvnaaqubhzihujf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase — agente IA (service role, apenas servidor)
SUPABASE_URL=https://mfrawrvnaaqubhzihujf.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Gemini — agente IA
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — transcrição de áudio
OPENAI_API_KEY=your_openai_api_key

# Evolution API — WhatsApp
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=vello

# Segurança — token enviado pela Evolution API no header X-Webhook-Token
WEBHOOK_TOKEN=your_webhook_secret_token

# Alertas — número que recebe notificação de lead Quente/Morno (formato: 5561999999999)
ALERT_WHATSAPP_NUMBER=

# Modo de teste — se definido, o agente responde apenas este número
ALLOWED_WHATSAPP=
