# Supabase — use a SERVICE ROLE KEY (não a anon key)
SUPABASE_URL=https://mfrawrvnaaqubhzihujf.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Gemini — agente IA
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — transcrição de áudio
OPENAI_API_KEY=your_openai_api_key

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=vello

# Servidor
PORT=3001

# Segurança — token que a Evolution API envia no header X-Webhook-Token
WEBHOOK_TOKEN=your_webhook_secret_token

# Alertas — número que recebe notificação quando lead Quente ou Morno é registrado
# Formato: código do país + DDD + número (ex: 5561999999999)
ALERT_WHATSAPP_NUMBER=
